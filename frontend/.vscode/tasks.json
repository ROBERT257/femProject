{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Frontend Dev Server",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev",
				"--",
				"--host",
				"127.0.0.1",
				"--port",
				"4173"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "build-frontend",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			],
			"group": "build"
		}
	]
}